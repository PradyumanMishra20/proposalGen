# OpenAI API Configuration
# Get your API key from https://platform.openai.com/api-keys
REACT_APP_OPENAI_API_KEY=your-openai-api-key-here

# Google Analytics Configuration (Optional)
# Get your Measurement ID from Google Analytics
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ANALYTICS_DEBUG=false

# Application Configuration
REACT_APP_APP_NAME=ProposalGen
REACT_APP_VERSION=1.0.0

# Contact Information
REACT_APP_SUPPORT_EMAIL=support@proposalgen.com
REACT_APP_CONTACT_EMAIL=contact@proposalgen.com
