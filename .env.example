# OpenAI API Configuration
# Replace with your actual API key from https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Gemini API Configuration (Alternative)
# Replace with your actual API key from https://aistudio.google.com/app/apikey
VITE_OPENROUTER_API_KEY=your_api_key_here

# Google Analytics Configuration
# Replace with your actual GA4 Measurement ID from Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Application Configuration
VITE_APP_NAME=ProposalGen
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ANALYTICS_DEBUG=false

# Contact Information (for footer modals)
VITE_SUPPORT_EMAIL=support@proposalgen.com
VITE_CONTACT_EMAIL=contact@proposalgen.com
